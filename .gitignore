# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo
.tsconfig.changed.json

# Export output (tg export markdown writes here by default)
exports/

# Productivity benchmark run output only; .benchmark/problems/ and README are committed
.benchmark/results/

# Integration test harness writes these under .taskgraph/
.taskgraph/tg-golden-template-path.txt
.taskgraph/tg-dolt-root-path.txt
.taskgraph/.tg-migration-version
.taskgraph/tg-test-server-pids.json
.taskgraph/tg-golden-server-pid.txt
.taskgraph/tg-dolt-server-port.txt
.taskgraph/sitrep-breadcrumb.json

# Test & coverage
coverage/

# Package manager
.pnpm-store/
.pnpm-debug.log*
.yarn-integrity

# Local env (integration test paths; Bun loads .env.local when running tests)
.env.local

# Learnings hook (transient; processed and deleted by next session)
.cursor/pending-learnings.md

# IDE & OS
.DS_Store
*.log
